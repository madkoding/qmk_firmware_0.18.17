#!/bin/bash
# QMK Pre-commit Hook
# Automatically compiles specified keyboards before each commit
# to ensure changes don't break the build.
# Skips compilation if qmk CLI is not available.

KEYBOARDS="crkbd:zonekeyboards sofle:zonekeyboards lily58:zonekeyboards lily58zk:zonekeyboards reviung41:zonekeyboards zkpad:default"
ERRORS=0
PARALLEL_JOBS=$(nproc)

echo "=========================================="
echo "QMK Pre-commit Build Check"
echo "=========================================="
echo ""

# Check if qmk CLI is available
if ! command -v qmk &> /dev/null || ! qmk hello &> /dev/null 2>&1; then
    echo "[SKIP] qmk CLI not available - skipping build check"
    echo "To enable: pip install qmk (requires qmk >= 1.3.0)"
    echo "=========================================="
    exit 0
fi

for kb in $KEYBOARDS; do
    keyboard=$(echo $kb | cut -d: -f1)
    keymap=$(echo $kb | cut -d: -f2)
    echo "Compiling ${keyboard}:${keymap}..."

    make ${keyboard}:${keymap} -j$PARALLEL_JOBS > /dev/null 2>&1
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo "[ERROR] ${keyboard}:${keymap} failed to compile"
        make ${keyboard}:${keymap} -j1 2>&1 | tail -10
        ERRORS=$((ERRORS + 1))
    else
        echo "[OK] ${keyboard}:${keymap}"
    fi
    echo ""
done

echo "=========================================="
if [ $ERRORS -gt 0 ]; then
    echo "BUILD FAILED: $ERRORS keyboard(s) had errors"
    echo "=========================================="
    exit 1
else
    echo "BUILD SUCCESS: All keyboards compiled"
    echo "=========================================="
    exit 0
fi