#!/bin/bash
# QMK Pre-commit Hook
# Automatically compiles specified keyboards before each commit
# to ensure changes don't break the build.
# Uses Docker if available, otherwise skips.

KEYBOARDS="crkbd:zonekeyboards sofle:zonekeyboards lily58:zonekeyboards lily58zk:zonekeyboards reviung41:zonekeyboards zkpad:default"
ERRORS=0

echo "=========================================="
echo "QMK Pre-commit Build Check"
echo "=========================================="
echo ""

# Check if Docker is available
if ! command -v docker &> /dev/null; then
    echo "[SKIP] Docker not available - skipping build check"
    echo "To enable: install Docker and run: ./util/docker-build.sh"
    echo "=========================================="
    exit 0
fi

# Create wrapper to handle missing qmk commands in container
WRAPPER_DIR=$(mktemp -d)
cat > "$WRAPPER_DIR/qmk" << 'WRAPPER'
#!/bin/bash
case "$1" in
    hello|list-keyboards|list-layouts|list-keymaps)
        exit 0
        ;;
    generate-*|generate.*)
        shift
        output_file=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                -o|--output)
                    output_file="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done
        if [[ -n "$output_file" && "$output_file" != -* ]]; then
            mkdir -p "$(dirname "$output_file")"
            touch "$output_file"
        fi
        exit 0
        ;;
    *)
        echo "qmk: unknown command: $1" >&2
        exit 1
        ;;
esac
WRAPPER
chmod +x "$WRAPPER_DIR/qmk"

for kb in $KEYBOARDS; do
    keyboard=$(echo $kb | cut -d: -f1)
    keymap=$(echo $kb | cut -d: -f2)
    echo "Building ${keyboard}:${keymap}..."

    docker run --rm \
        -v "$(pwd)":/qmk \
        -v "$WRAPPER_DIR":/wrapper \
        -w /qmk \
        qmkfm/qmk_cli:latest \
        sh -c "git config --global --add safe.directory /qmk && cp /wrapper/qmk /opt/uv/tools/qmk/bin/qmk && chmod +x /opt/uv/tools/qmk/bin/qmk && make ${keyboard}:${keymap} SKIP_GIT=yes" > /dev/null 2>&1

    if [ $? -ne 0 ]; then
        echo "[ERROR] ${keyboard}:${keymap} failed to compile"
        ERRORS=$((ERRORS + 1))
    else
        echo "[OK] ${keyboard}:${keymap}"
    fi
    echo ""
done

rm -rf "$WRAPPER_DIR"

echo "=========================================="
if [ $ERRORS -gt 0 ]; then
    echo "BUILD FAILED: $ERRORS keyboard(s) had errors"
    echo "=========================================="
    exit 1
else
    echo "BUILD SUCCESS: All keyboards compiled"
    echo "=========================================="
    exit 0
fi